# Local development variable overrides (per-developer).
#
# Copy this file to dev-variables.yml in the same directory and edit
# the values for your workspace. The dev-variables.yml file is
# git-ignored; this .template file is committed as documentation.
#
# Why a `targets:` block?
# Databricks bundle variable resolution: target-level `variables:` always
# wins over an include file's top-level `variables: <name>: default:`.
# To actually override the `dev` target, the overrides must live INSIDE
# `targets.dev.variables`, not under top-level `variables:`.
#
# Replace the placeholders below (<your_catalog>, <your_username>,
# <your_volume>) with values for your own workspace and volume.

targets:
  dev:
    variables:
      catalog: "<your_catalog>"
      emir_raw_schema: "<your_username>"
      emir_landing_path: "/Volumes/<your_catalog>/<your_username>/<your_volume>/landing/"
      emir_xml_schema_pyld_path: "/Volumes/<your_catalog>/<your_username>/<your_volume>/schemas/pyld_schema.json"
      emir_xml_schema_hdr_pyld_metadata_path: "/Volumes/<your_catalog>/<your_username>/<your_volume>/schemas/hdr_pyld_metadata_schema.json"
      emir_xml_xsd_schema_pyld_path: "/Volumes/<your_catalog>/<your_username>/<your_volume>/schemas/row_tag_schema.xsd"
